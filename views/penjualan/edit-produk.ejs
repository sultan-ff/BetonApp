<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Produk - Panel Penjualan MBP</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    
    <style>
        /* ==================== CETAKAN STRUKTUR WAJIB KONSISTEN ==================== */
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { margin: 0; padding: 0; font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif; background-color: #f4f7f6; display: flex; min-height: 100vh; }
        
        .main-content {
            margin-left: 260px;
            padding: 40px;
            width: calc(100% - 260px);
            box-sizing: border-box;
            min-height: 100vh;
        }
        .topbar { 
            display: flex; justify-content: flex-end; align-items: center; 
            margin-bottom: 30px; padding-bottom: 20px; border-bottom: 1px solid #e2e8f0;
        }
        .admin-profile { 
            display: flex; align-items: center; gap: 12px; background: white; 
            padding: 8px 20px; border-radius: 30px; border: 1px solid #e2e8f0; 
            font-weight: 600; color: #1e293b; font-size: 14px; box-shadow: 0 2px 5px rgba(0,0,0,0.02);
        }
        .admin-profile i { color: #03ac0e; font-size: 18px; }
        /* ========================================================================== */

        /* Header & Form Area */
        .page-header-container { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 30px; }
        .page-header h2 { font-weight: 800; color: #14532d; font-size: 26px; margin: 0 0 5px 0; }
        .page-header p { color: #64748b; font-size: 15px; margin: 0; }
        
        .btn-back { background: white; color: #475569; border: 1px solid #cbd5e1; border-radius: 8px; padding: 10px 20px; font-size: 14px; font-weight: 600; text-decoration: none; transition: 0.2s; display: inline-flex; align-items: center; gap: 8px; }
        .btn-back:hover { background: #f1f5f9; color: #1e293b; }

        /* Form Card Styling */
        .form-card { background: white; border-radius: 16px; padding: 35px 40px; box-shadow: 0 4px 15px rgba(0,0,0,0.02); border: 1px solid #e2e8f0; max-width: 700px; }
        .form-label { font-size: 13.5px; font-weight: 700; color: #334155; margin-bottom: 8px; display: block; }
        .form-control, .form-select { width: 100%; padding: 12px 16px; border: 1px solid #cbd5e1; border-radius: 8px; font-size: 14px; transition: 0.2s; background-color: #f8fafc; color: #1e293b; margin-bottom: 20px; }
        .form-control:focus, .form-select:focus { border-color: #03ac0e; outline: none; background-color: white; box-shadow: 0 0 0 3px rgba(3, 172, 14, 0.1); }
        
        /* Preview Image Styling */
        .img-preview-box { background: #f8fafc; border: 1px dashed #cbd5e1; border-radius: 8px; padding: 15px; text-align: center; margin-bottom: 20px; display: flex; flex-direction: column; align-items: center; gap: 10px; }
        .img-preview-box img { max-width: 150px; border-radius: 8px; box-shadow: 0 2px 5px rgba(0,0,0,0.1); }
        .img-preview-box span { font-size: 12px; color: #64748b; font-weight: 600; }

        .btn-submit { width: 100%; background: #16a34a; color: white; border: none; padding: 14px; border-radius: 8px; font-weight: 700; font-size: 15px; cursor: pointer; transition: 0.2s; display: flex; align-items: center; justify-content: center; gap: 8px; margin-top: 10px; }
        .btn-submit:hover { background: #15803d; transform: translateY(-2px); box-shadow: 0 4px 10px rgba(22, 163, 74, 0.2); }
    </style>
</head>
<body>

    <%- include('../partials/sidebar', { role: role }) %>

    <div class="main-content">
        <div class="topbar">
            <div class="admin-profile">
                <i class="bi bi-person-circle"></i>
                <%= typeof namaUser !== 'undefined' ? namaUser : 'Tim Penjualan' %>
                <span style="background: #f1f5f9; padding: 2px 10px; border-radius: 12px; font-size: 11px; color: #64748b; margin-left: 5px;">Penjualan</span>
            </div>
        </div>

        <div class="page-header-container">
            <div class="page-header">
                <h2>Edit Data Produk</h2>
                <p>Perbarui informasi detail, harga, atau foto dari produk ini.</p>
            </div>
            <a href="/penjualan/produk" class="btn-back">
                <i class="bi bi-arrow-left"></i> Kembali ke Katalog
            </a>
        </div>

        <div class="form-card">
            <form action="/penjualan/produk/update/<%= produk.id %>" method="POST" enctype="multipart/form-data">
                
                <label class="form-label">Nama Produk / Mutu Beton</label>
                <input type="text" name="nama_produk" class="form-control" value="<%= produk.nama_produk %>" required>

                <label class="form-label">Kategori</label>
                <select name="kategori_id" class="form-select" required>
                    <option value="" disabled>-- Pilih Kategori --</option>
                    <% kategori.forEach(k => { %>
                        <option value="<%= k.id %>" <%= produk.kategori_id === k.id ? 'selected' : '' %>>
                            <%= k.nama_kategori %>
                        </option>
                    <% }) %>
                </select>

                <label class="form-label">Harga Produk (Rp)</label>
                <input type="number" name="harga" class="form-control" value="<%= produk.harga %>" required>

                <label class="form-label">Foto Produk Saat Ini</label>
                <div class="img-preview-box">
                    <% if(produk.foto) { %>
                        <img src="/uploads/<%= produk.foto %>" alt="Foto Asli">
                        <span>Biarkan kosong jika tidak ingin mengubah foto.</span>
                    <% } else { %>
                        <div style="font-size: 30px; color: #cbd5e1;"><i class="bi bi-image"></i></div>
                        <span>Produk ini belum memiliki foto.</span>
                    <% } %>
                </div>

                <label class="form-label">Ganti Foto Baru (Opsional)</label>
                <input type="file" name="foto" class="form-control" accept="image/*">
                <label class="form-label">Deskripsi / Kegunaan Produk</label>
                <textarea name="deskripsi" class="form-control" rows="4" required><%= produk.deskripsi || '' %></textarea>

                <button type="submit" class="btn-submit">
                    <i class="bi bi-save2-fill"></i> Simpan Perubahan Produk
                </button>
            </form>
        </div>

    </div>

</body>
</html>
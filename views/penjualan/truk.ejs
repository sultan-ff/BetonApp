<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kelola Armada Truk - Panel Penjualan MBP</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    
    <style>
        /* ==================== CETAKAN STRUKTUR WAJIB KONSISTEN ==================== */
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { margin: 0; padding: 0; font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif; background-color: #f4f7f6; display: flex; min-height: 100vh; }
        
        .main-content { margin-left: 260px; padding: 40px; width: calc(100% - 260px); box-sizing: border-box; min-height: 100vh; }
        .topbar { display: flex; justify-content: flex-end; align-items: center; margin-bottom: 30px; padding-bottom: 20px; border-bottom: 1px solid #e2e8f0; }
        .admin-profile { display: flex; align-items: center; gap: 12px; background: white; padding: 8px 20px; border-radius: 30px; border: 1px solid #e2e8f0; font-weight: 600; color: #1e293b; font-size: 14px; box-shadow: 0 2px 5px rgba(0,0,0,0.02); }
        .admin-profile i { color: #03ac0e; font-size: 18px; }
        /* ========================================================================== */

        .page-header-container { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 30px; }
        .page-header h2 { font-weight: 800; color: #14532d; font-size: 26px; margin: 0 0 5px 0; }
        .page-header p { color: #64748b; font-size: 15px; margin: 0; }
        
        .btn-add { background: #16a34a; color: white; border-radius: 8px; padding: 10px 20px; font-size: 14px; font-weight: 600; text-decoration: none; transition: 0.2s; display: inline-flex; align-items: center; gap: 8px; box-shadow: 0 4px 6px rgba(22, 163, 74, 0.2); }
        .btn-add:hover { background: #15803d; color: white; transform: translateY(-2px); box-shadow: 0 6px 12px rgba(22, 163, 74, 0.3); }

        .card-table { background: white; border-radius: 16px; box-shadow: 0 4px 10px rgba(0,0,0,0.02); border: 1px solid #e2e8f0; overflow: hidden; }
        .table { width: 100%; margin-bottom: 0; border-collapse: collapse; }
        .table thead th { background-color: #f8fafc; color: #475569; font-size: 12px; font-weight: 700; text-transform: uppercase; padding: 18px 20px; border-bottom: 1px solid #e2e8f0; border-top: none; letter-spacing: 0.5px; }
        .table tbody td { padding: 18px 20px; vertical-align: middle; border-bottom: 1px solid #f1f5f9; font-size: 14px; color: #334155; }
        .table tbody tr:hover { background-color: #f0fdf4; }
        
        /* Status Truk */
        .status-badge { padding: 6px 12px; border-radius: 20px; font-size: 11px; font-weight: 700; text-transform: uppercase; display: inline-block; letter-spacing: 0.5px; }
        .bg-tersedia { background: #dcfce7; color: #166534; border: 1px solid #bbf7d0; }
        .bg-jalan { background: #e0f2fe; color: #0369a1; border: 1px solid #bae6fd; }
        .bg-rusak { background: #fee2e2; color: #b91c1c; border: 1px solid #fecaca; }

        .btn-edit { background: #eff6ff; color: #2563eb; border: none; padding: 8px 14px; border-radius: 6px; font-size: 13px; font-weight: 600; cursor: pointer; text-decoration: none; display: inline-flex; align-items: center; gap: 6px; transition: 0.2s; margin-right: 5px; }
        .btn-edit:hover { background: #3b82f6; color: white; }
    </style>
</head>
<body>

    <%- include('../partials/sidebar', { role: role }) %>

    <div class="main-content">
        <div class="topbar">
            <div class="admin-profile">
                <i class="bi bi-person-circle"></i>
                <%= typeof namaUser !== 'undefined' ? namaUser : 'Tim Penjualan' %>
                <span style="background: #f1f5f9; padding: 2px 10px; border-radius: 12px; font-size: 11px; color: #64748b; margin-left: 5px;">Penjualan</span>
            </div>
        </div>

        <div class="page-header-container">
            <div class="page-header">
                <h2>Kelola Armada Truk</h2>
                <p>Pantau ketersediaan truk mixer dan kelola kapasitas muatan armada.</p>
            </div>
            <a href="/penjualan/truk/tambah" class="btn-add">
                <i class="bi bi-plus-lg"></i> Tambah Armada
            </a>
        </div>

        <div class="card-table table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th>Plat Nomor</th>
                        <th>Kapasitas</th>
                        <th>Nama Driver</th>
                        <th>Status Kendaraan</th>
                        <th style="text-align: center;">Aksi</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (typeof armada === 'undefined' || armada.length === 0) { %>
                        <tr>
                            <td colspan="5" style="text-align: center; padding: 40px; color: #94a3b8;">
                                <i class="bi bi-truck fs-1 d-block mb-2"></i>
                                Belum ada data truk armada.
                            </td>
                        </tr>
                    <% } else { %>
                        <% armada.forEach(t => { 
                            // Logika mencocokkan ENUM database
                            let statusTruk = t.status_kendaraan ? t.status_kendaraan.toLowerCase() : 'tersedia';
                            let badgeClass = 'bg-tersedia';
                            let textStatus = 'Tersedia';

                            if (statusTruk === 'beroperasi') { 
                                badgeClass = 'bg-jalan'; 
                                textStatus = 'Beroperasi'; 
                            } else if (statusTruk === 'rusak') { 
                                badgeClass = 'bg-rusak'; 
                                textStatus = 'Rusak / Perawatan'; 
                            }
                        %>
                        <tr>
                            <td class="fw-bold text-dark"><i class="bi bi-truck-front text-muted me-2"></i><%= t.plat_nomor %></td>
                            <td>
                                <span style="background: #f1f5f9; color: #475569; padding: 4px 10px; border-radius: 6px; font-size: 13px; font-weight: 600;">
                                    <%= Number(t.kapasitas).toFixed(1) %> m³
                                </span>
                            </td>
                            <td class="fw-bold" style="color: #334155;"><%= t.nama_driver %></td>
                            <td>
                                <span class="status-badge <%= badgeClass %>">
                                    <%= textStatus %>
                                </span>
                            </td>
                            <td style="text-align: center; white-space: nowrap;">
                                <a href="/penjualan/truk/edit/<%= t.id %>" class="btn-edit">
                                    <i class="bi bi-pencil-square"></i> Edit
                                </a>
                            </td>
                        </tr>
                        <% }) %>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</body>
</html>
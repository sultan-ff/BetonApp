<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kelola Produk - Panel Penjualan MBP</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    
    <style>
        /* ==================== CETAKAN STRUKTUR WAJIB KONSISTEN ==================== */
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { margin: 0; padding: 0; font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif; background-color: #f4f7f6; display: flex; min-height: 100vh; }
        
        .main-content {
            margin-left: 260px; /* Mengunci jarak agar pas dengan lebar sidebar */
            padding: 40px;
            width: calc(100% - 260px);
            box-sizing: border-box;
            min-height: 100vh;
        }
        .topbar { 
            display: flex; justify-content: flex-end; align-items: center; 
            margin-bottom: 30px; padding-bottom: 20px; border-bottom: 1px solid #e2e8f0;
        }
        .admin-profile { 
            display: flex; align-items: center; gap: 12px; background: white; 
            padding: 8px 20px; border-radius: 30px; border: 1px solid #e2e8f0; 
            font-weight: 600; color: #1e293b; font-size: 14px; box-shadow: 0 2px 5px rgba(0,0,0,0.02);
        }
        .admin-profile i { color: #03ac0e; font-size: 18px; }
        /* ========================================================================== */

        /* Header Halaman & Tombol Tambah */
        .page-header-container { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 30px; }
        .page-header h2 { font-weight: 800; color: #14532d; font-size: 26px; margin: 0 0 5px 0; }
        .page-header p { color: #64748b; font-size: 15px; margin: 0; }
        
        .btn-add { background: #16a34a; color: white; border-radius: 8px; padding: 10px 20px; font-size: 14px; font-weight: 600; text-decoration: none; transition: 0.2s; display: inline-flex; align-items: center; gap: 8px; box-shadow: 0 4px 6px rgba(22, 163, 74, 0.2); }
        .btn-add:hover { background: #15803d; color: white; transform: translateY(-2px); box-shadow: 0 6px 12px rgba(22, 163, 74, 0.3); }

        /* Styling Tabel */
        .card-table { background: white; border-radius: 16px; box-shadow: 0 4px 10px rgba(0,0,0,0.02); border: 1px solid #e2e8f0; overflow: hidden; }
        .table { width: 100%; margin-bottom: 0; border-collapse: collapse; }
        .table thead th { background-color: #f8fafc; color: #475569; font-size: 12px; font-weight: 700; text-transform: uppercase; padding: 18px 20px; border-bottom: 1px solid #e2e8f0; border-top: none; letter-spacing: 0.5px; }
        .table tbody td { padding: 15px 20px; vertical-align: middle; border-bottom: 1px solid #f1f5f9; font-size: 14px; color: #334155; }
        .table tbody tr:hover { background-color: #f0fdf4; }
        
        /* Thumbnail Foto Produk */
        .product-img { width: 50px; height: 50px; object-fit: cover; border-radius: 8px; border: 1px solid #e2e8f0; background-color: #f8fafc; }
        .no-img { width: 50px; height: 50px; border-radius: 8px; background-color: #f1f5f9; color: #94a3b8; display: flex; align-items: center; justify-content: center; font-size: 20px; border: 1px dashed #cbd5e1; }
        
        /* Label Teks Tabel */
        .prod-name { font-weight: 700; color: #1e293b; margin: 0; font-size: 15px; }
        .prod-cat { background: #f1f5f9; color: #475569; padding: 4px 10px; border-radius: 6px; font-size: 12px; font-weight: 600; display: inline-block; }
        .prod-price { font-weight: 700; color: #059669; }

        /* Tombol Hapus */
        .btn-delete { background: #fee2e2; color: #dc2626; border: none; padding: 8px 14px; border-radius: 6px; font-size: 13px; font-weight: 600; cursor: pointer; text-decoration: none; display: inline-flex; align-items: center; gap: 6px; transition: 0.2s; }
        .btn-delete:hover { background: #f87171; color: white; }
        /* Tombol Edit */
        .btn-edit { background: #eff6ff; color: #2563eb; border: none; padding: 8px 14px; border-radius: 6px; font-size: 13px; font-weight: 600; cursor: pointer; text-decoration: none; display: inline-flex; align-items: center; gap: 6px; transition: 0.2s; margin-right: 5px; }
        .btn-edit:hover { background: #3b82f6; color: white; }
    </style>
</head>
<body>

    <%- include('../partials/sidebar', { role: role }) %>

    <div class="main-content">
        <div class="topbar">
            <div class="admin-profile">
                <i class="bi bi-person-circle"></i>
                <%= typeof namaUser !== 'undefined' ? namaUser : 'Tim Penjualan' %>
                <span style="background: #f1f5f9; padding: 2px 10px; border-radius: 12px; font-size: 11px; color: #64748b; margin-left: 5px;">Penjualan</span>
            </div>
        </div>

        <div class="page-header-container">
            <div class="page-header">
                <h2>Kelola Katalog Produk</h2>
                <p>Daftar semua produk beton dan sewa alat yang tersedia untuk pelanggan.</p>
            </div>
            
            <a href="/penjualan/produk/tambah" class="btn-add">
                <i class="bi bi-plus-lg"></i> Tambah Produk Baru
            </a>
        </div>

        <div class="card-table table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th style="width: 80px; text-align: center;">Foto</th>
                        <th>Nama Produk</th>
                        <th>Kategori</th>
                        <th>Harga (Rp)</th>
                        <th style="text-align: center;">Aksi</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (typeof produk === 'undefined' || produk.length === 0) { %>
                        <tr>
                            <td colspan="5" style="text-align: center; padding: 40px 20px; color: #94a3b8;">
                                <i class="bi bi-box-seam fs-1 d-block mb-2"></i>
                                Belum ada produk di dalam katalog.
                            </td>
                        </tr>
                    <% } else { %>
                        <% produk.forEach(p => { %>
                        <tr>
                            <td style="text-align: center;">
                                <% if(p.foto) { %>
                                    <img src="/uploads/<%= p.foto %>" alt="Foto <%= p.nama_produk %>" class="product-img">
                                <% } else { %>
                                    <div class="no-img" title="Tidak ada foto">
                                        <i class="bi bi-image"></i>
                                    </div>
                                <% } %>
                            </td>
                            <td>
                                <p class="prod-name"><%= p.nama_produk %></p>
                            </td>
                            <td>
                                <span class="prod-cat"><%= p.nama_kategori %></span>
                            </td>
                            <td class="prod-price">
                                Rp <%= Number(p.harga).toLocaleString('id-ID') %>
                            </td>
                            <td style="text-align: center; white-space: nowrap;">
                                <a href="/penjualan/produk/edit/<%= p.id %>" class="btn-edit">
                                    <i class="bi bi-pencil-square"></i> Edit
                                </a>
                                
                                <a href="/penjualan/produk/hapus/<%= p.id %>" class="btn-delete" onclick="return confirm('Apakah Anda yakin ingin menghapus produk: <%= p.nama_produk %>?');">
                                    <i class="bi bi-trash3-fill"></i> Hapus
                                </a>
                            </td>
                        </tr>
                        <% }) %>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>

    <% if (typeof includeFooter !== 'undefined' && includeFooter) { %>
        <%- include('../partials/footer') %>
    <% } %>
</body>
</html>
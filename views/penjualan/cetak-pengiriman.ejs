<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cetak Laporan Pengiriman - PT Mitrabeton Perkasa</title>
    <style>
        /* Styling Khusus Kertas HVS / Cetak */
        body {
            font-family: 'Times New Roman', Times, serif;
            color: #000;
            background: #fff;
            margin: 0;
            padding: 20px 40px;
        }
        
        /* Kop Surat */
        .kop-surat {
            display: flex;
            align-items: center;
            justify-content: space-between;
            border-bottom: 4px double #000;
            padding-bottom: 15px;
            margin-bottom: 25px;
        }
        
        .logo-container {
            width: 50px;
            display: flex;
            justify-content: flex-start;
        }
        
        .logo-img {
            width: 110px;
            height: auto;
        }
        
        .teks-kop {
            flex: 1;
            text-align: center;
        }
        
        .teks-kop h1 {
            margin: 0 0 5px 0;
            font-size: 26px;
            font-weight: 900;
            font-family: 'Times New Roman', Times, serif;
            letter-spacing: 1px;
            color: #01682f; /* Warna hijau khas perusahaan */
        }
        
        .teks-kop p {
            margin: 2px 0;
            font-size: 14px;
            color: #000;
            font-family: 'Times New Roman', Times, serif;
        }

        .spacer-kanan {
            width: 50px;
        }

        /* Detail Dokumen */
        .detail-dokumen {
            margin-bottom: 20px;
        }
        .detail-dokumen table {
            font-size: 14px;
        }
        .detail-dokumen td {
            padding: 3px 10px 3px 0;
            vertical-align: top;
        }

        /* Tabel Data */
        h3 {
            text-align: center;
            margin-bottom: 15px;
        }
        .tabel-data {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 40px;
        }
        .tabel-data th, .tabel-data td {
            border: 1px solid #000;
            padding: 8px;
            text-align: center;
            font-size: 14px;
        }

        /* Bagian Tanda Tangan */
        .ttd-section {
            width: 100%;
            margin-top: 50px;
            display: flex;
            justify-content: flex-end;
        }
        .ttd-box {
            text-align: center;
            width: 250px;
            font-size: 14px;
        }

        /* Pengaturan Print */
        @media print {
            @page { margin: 2cm; }
            button { display: none !important; }
        }
    </style>
</head>
<body onload="window.print()">

    <div class="kop-surat">
        <div class="logo-container">
            <img src="/images/logo-mitrabeton.png" alt="Logo PT Mitrabeton Perkasa" class="logo-img">
        </div>
        
        <div class="teks-kop">
            <h1>PT. MITRABETON PERKASA</h1>
            <p>Jl. Lingkar Barat-Blok Kidul Kal, Pasuruhan Kidul – Jati Kab. Kudus</p>
            <p>E-mail: mitrabeton_perkasa@yahoo.com</p>
        </div>
        
        <div class="spacer-kanan"></div>
    </div>

    <div class="detail-dokumen">
        <table>
            <tr>
                <td>Tanggal Cetak</td>
                <td>: <%= typeof tanggalCetak !== 'undefined' ? tanggalCetak : new Date().toLocaleDateString('id-ID') %></td>
            </tr>
            <tr>
                <td>Dokumen</td>
                <td>: Laporan Riwayat Pengiriman Selesai</td>
            </tr>
        </table>
    </div>

    <h3>Data Laporan Pengiriman</h3>

    <table class="tabel-data">
        <thead>
            <tr>
                <th>Nomor</th>
                <th>ID Pesanan</th>
                <th>Nama Pelanggan</th>
                <th>Mutu Beton</th>
                <th>Armada Truk (Nopol)</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            <% if(typeof riwayatSelesai === 'undefined' || riwayatSelesai.length === 0) { %>
                <tr>
                    <td colspan="6">Tidak ada data riwayat pengiriman.</td>
                </tr>
            <% } else { %>
                <% riwayatSelesai.forEach((item, index) => { %>
                <tr>
                    <td><%= index + 1 %></td>
                    <td style="font-family: monospace; font-weight: bold;">INV-<%= item.id %></td>
                    <td style="text-align: left; padding-left: 15px;"><%= item.pelanggan %></td>
                    <td><%= item.nama_produk %></td>
                    <td><%= item.no_polisi %></td>
                    <td>TERKIRIM</td>
                </tr>
                <% }) %>
            <% } %>
        </tbody>
    </table>

    <div class="ttd-section">
        <div class="ttd-box">
            <div style="margin-bottom: 5px;">Kudus, <%= typeof tanggalCetak !== 'undefined' ? tanggalCetak : new Date().toLocaleDateString('id-ID') %></div>
            <div>Pembuat Laporan,</div>
            
            <br><br><br><br>
            
            <div style="text-transform: uppercase;">
                <strong><u><%= typeof namaUser !== 'undefined' ? namaUser : 'Admin Penjualan' %></u></strong>
            </div>
            <div>Bagian Penjualan</div>
        </div>
    </div>

</body>
</html>
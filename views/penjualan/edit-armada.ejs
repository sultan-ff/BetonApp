<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Armada - Panel Penjualan MBP</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    
    <style>
        /* ==================== CETAKAN STRUKTUR WAJIB KONSISTEN ==================== */
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { margin: 0; padding: 0; font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif; background-color: #f4f7f6; display: flex; min-height: 100vh; }
        
        .main-content { margin-left: 260px; padding: 40px; width: calc(100% - 260px); box-sizing: border-box; min-height: 100vh; }
        .topbar { display: flex; justify-content: flex-end; align-items: center; margin-bottom: 30px; padding-bottom: 20px; border-bottom: 1px solid #e2e8f0; }
        .admin-profile { display: flex; align-items: center; gap: 12px; background: white; padding: 8px 20px; border-radius: 30px; border: 1px solid #e2e8f0; font-weight: 600; color: #1e293b; font-size: 14px; box-shadow: 0 2px 5px rgba(0,0,0,0.02); }
        .admin-profile i { color: #03ac0e; font-size: 18px; }
        /* ========================================================================== */

        .page-header-container { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 30px; }
        .page-header h2 { font-weight: 800; color: #14532d; font-size: 26px; margin: 0 0 5px 0; }
        .page-header p { color: #64748b; font-size: 15px; margin: 0; }
        
        .btn-back { background: white; color: #475569; border: 1px solid #cbd5e1; border-radius: 8px; padding: 10px 20px; font-size: 14px; font-weight: 600; text-decoration: none; transition: 0.2s; display: inline-flex; align-items: center; gap: 8px; }
        .btn-back:hover { background: #f1f5f9; color: #1e293b; }

        .form-card { background: white; border-radius: 16px; padding: 35px 40px; box-shadow: 0 4px 15px rgba(0,0,0,0.02); border: 1px solid #e2e8f0; max-width: 650px; }
        .form-label { font-size: 13.5px; font-weight: 700; color: #334155; margin-bottom: 8px; display: block; }
        .form-control, .form-select { width: 100%; padding: 12px 16px; border: 1px solid #cbd5e1; border-radius: 8px; font-size: 14px; transition: 0.2s; background-color: #f8fafc; color: #1e293b; margin-bottom: 20px; }
        .form-control:focus, .form-select:focus { border-color: #03ac0e; outline: none; background-color: white; box-shadow: 0 0 0 3px rgba(3, 172, 14, 0.1); }
        
        .btn-submit { width: 100%; background: #16a34a; color: white; border: none; padding: 14px; border-radius: 8px; font-weight: 700; font-size: 15px; cursor: pointer; transition: 0.2s; display: flex; align-items: center; justify-content: center; gap: 8px; margin-top: 10px; }
        .btn-submit:hover { background: #15803d; transform: translateY(-2px); box-shadow: 0 4px 10px rgba(22, 163, 74, 0.2); }
        .btn-danger-custom { width: 100%; background: #fef2f2; color: #dc2626; border: 1px solid #fca5a5; padding: 10px; border-radius: 8px; font-weight: 600; font-size: 13.5px; text-decoration: none; display: inline-flex; align-items: center; justify-content: center; gap: 6px; margin-top: 15px; transition: 0.2s; }
        .btn-danger-custom:hover { background: #dc2626; color: white; }
    </style>
</head>
<body>

    <%- include('../partials/sidebar', { role: role }) %>

    <div class="main-content">
        <div class="topbar">
            <div class="admin-profile">
                <i class="bi bi-person-circle"></i>
                <%= typeof namaUser !== 'undefined' ? namaUser : 'Tim Penjualan' %>
                <span style="background: #f1f5f9; padding: 2px 10px; border-radius: 12px; font-size: 11px; color: #64748b; margin-left: 5px;">Penjualan</span>
            </div>
        </div>

        <div class="page-header-container">
            <div class="page-header">
                <h2>Edit Data Armada</h2>
                <p>Perbarui informasi plat nomor, kapasitas muatan, supir, atau status operasional unit.</p>
            </div>
            <a href="/penjualan/truk" class="btn-back">
                <i class="bi bi-arrow-left"></i> Kembali
            </a>
        </div>

        <div class="form-card">
            <form action="/penjualan/truk/update/<%= truk.id %>" method="POST">
                
                <label class="form-label">Plat Nomor Kendaraan</label>
                <input type="text" name="plat_nomor" class="form-control" value="<%= truk.plat_nomor %>" required style="text-transform: uppercase;">

                <label class="form-label">Kapasitas Muatan (m³)</label>
                <input type="number" name="kapasitas" step="0.1" class="form-control" value="<%= truk.kapasitas %>" required>

                <label class="form-label">Nama Supir / Driver</label>
                <input type="text" name="nama_driver" class="form-control" value="<%= truk.nama_driver %>" required>

                <label class="form-label">Status Kendaraan</label>
                <select name="status_kendaraan" class="form-select" required>
                    <% let currentStatus = truk.status_kendaraan ? truk.status_kendaraan.toLowerCase() : 'tersedia'; %>
                    <option value="tersedia" <%= currentStatus === 'tersedia' ? 'selected' : '' %>>Tersedia (Ready di Pool)</option>
                    <option value="beroperasi" <%= currentStatus === 'beroperasi' ? 'selected' : '' %>>Beroperasi (Kirim Cor)</option>
                    <option value="rusak" <%= currentStatus === 'rusak' ? 'selected' : '' %>>Rusak / Perawatan</option>
                </select>

                <button type="submit" class="btn-submit">
                    <i class="bi bi-save2-fill"></i> Simpan Perubahan Armada
                </button>

                <a href="/penjualan/truk/hapus/<%= truk.id %>" class="btn-danger-custom" onclick="return confirm('Hapus unit armada <%= truk.plat_nomor %> dari sistem?');">
                    <i class="bi bi-trash3"></i> Hapus Armada Ini
                </a>
            </form>
        </div>
    </div>
</body>
</html>
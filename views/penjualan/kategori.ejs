<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kelola Kategori - Panel Penjualan MBP</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    
    <style>
        /* ==================== CETAKAN STRUKTUR WAJIB KONSISTEN ==================== */
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { margin: 0; padding: 0; font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif; background-color: #f4f7f6; display: flex; min-height: 100vh; }
        
        .main-content {
            margin-left: 260px; /* Mengunci jarak agar pas dengan lebar sidebar */
            padding: 40px;
            width: calc(100% - 260px);
            box-sizing: border-box;
            min-height: 100vh;
        }
        .topbar { 
            display: flex; justify-content: flex-end; align-items: center; 
            margin-bottom: 30px; padding-bottom: 20px; border-bottom: 1px solid #e2e8f0;
        }
        .admin-profile { 
            display: flex; align-items: center; gap: 12px; background: white; 
            padding: 8px 20px; border-radius: 30px; border: 1px solid #e2e8f0; 
            font-weight: 600; color: #1e293b; font-size: 14px; box-shadow: 0 2px 5px rgba(0,0,0,0.02);
        }
        .admin-profile i { color: #03ac0e; font-size: 18px; }
        /* ========================================================================== */

        /* Header Halaman */
        .page-header { margin-bottom: 30px; }
        .page-header h2 { font-weight: 800; color: #14532d; font-size: 26px; margin: 0 0 5px 0; }
        .page-header p { color: #64748b; font-size: 15px; margin: 0; }

        /* Layout Kiri (Form) dan Kanan (Tabel) */
        .layout-split {
            display: grid;
            grid-template-columns: 1fr 2fr; /* Proporsi: 1 bagian form, 2 bagian tabel */
            gap: 30px;
            align-items: start;
        }

        /* Desain Kartu (Card) */
        .card-box {
            background: white;
            border-radius: 16px;
            padding: 25px 30px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.02);
            border: 1px solid #e2e8f0;
        }
        .card-box h3 { font-size: 18px; font-weight: 700; color: #1e293b; margin-bottom: 20px; border-bottom: 2px solid #f1f5f9; padding-bottom: 15px; }

        /* Form Styling */
        .form-label { font-size: 13px; font-weight: 600; color: #475569; margin-bottom: 8px; display: block; }
        .form-control { width: 100%; padding: 12px 16px; border: 1px solid #cbd5e1; border-radius: 8px; font-size: 14px; transition: 0.2s; background-color: #f8fafc; color: #1e293b; }
        .form-control:focus { border-color: #03ac0e; outline: none; background-color: white; box-shadow: 0 0 0 3px rgba(3, 172, 14, 0.1); }
        .btn-submit { width: 100%; background: #16a34a; color: white; border: none; padding: 12px; border-radius: 8px; font-weight: 600; font-size: 14px; cursor: pointer; transition: 0.2s; margin-top: 15px; display: flex; align-items: center; justify-content: center; gap: 8px; }
        .btn-submit:hover { background: #15803d; transform: translateY(-2px); box-shadow: 0 4px 10px rgba(22, 163, 74, 0.2); }

        /* Table Styling */
        .table-responsive { overflow-x: auto; margin: 0 -30px; padding: 0 30px; }
        .table { width: 100%; border-collapse: collapse; margin-bottom: 0; }
        .table thead th { background-color: #f8fafc; color: #475569; font-size: 12px; font-weight: 700; text-transform: uppercase; padding: 15px 20px; border-bottom: 1px solid #e2e8f0; border-top: none; letter-spacing: 0.5px; text-align: left; }
        .table tbody td { padding: 18px 20px; vertical-align: middle; border-bottom: 1px solid #f1f5f9; font-size: 14px; color: #334155; }
        .table tbody tr:hover { background-color: #f0fdf4; }
        
        .cat-id { font-weight: 700; color: #94a3b8; }
        .cat-name { font-weight: 600; color: #1e293b; }

        /* Tombol Hapus */
        .btn-delete { background: #fee2e2; color: #dc2626; border: none; padding: 6px 14px; border-radius: 6px; font-size: 12px; font-weight: 700; cursor: pointer; text-decoration: none; display: inline-flex; align-items: center; gap: 6px; transition: 0.2s; }
        .btn-delete:hover { background: #f87171; color: white; }

        /* Responsif untuk layar kecil */
        @media (max-width: 992px) {
            .layout-split { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>

    <%- include('../partials/sidebar', { role: role }) %>

    <div class="main-content">
        <div class="topbar">
            <div class="admin-profile">
                <i class="bi bi-person-circle"></i>
                <%= typeof namaUser !== 'undefined' ? namaUser : 'Tim Penjualan' %>
                <span style="background: #f1f5f9; padding: 2px 10px; border-radius: 12px; font-size: 11px; color: #64748b; margin-left: 5px;">Penjualan</span>
            </div>
        </div>

        <div class="page-header">
            <h2>Kelola Kategori Produk</h2>
            <p>Tambahkan dan atur jenis kategori beton atau alat yang tersedia di katalog.</p>
        </div>

        <div class="layout-split">
            <div class="card-box">
                <h3><i class="bi bi-plus-square-fill text-success me-2"></i> Tambah Kategori Baru</h3>
                
                <form action="/penjualan/kategori/tambah" method="POST">
                    <label class="form-label">Nama Kategori</label>
                    <input type="text" name="nama_kategori" class="form-control" required placeholder="Contoh: Beton Struktural" autocomplete="off">
                    
                    <button type="submit" class="btn-submit">
                        <i class="bi bi-floppy-fill"></i> Simpan Kategori
                    </button>
                </form>
            </div>

            <div class="card-box" style="padding: 25px 0;">
                <h3 style="padding: 0 30px;"><i class="bi bi-list-ul text-success me-2"></i> Daftar Kategori Aktif</h3>
                
                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Nama Kategori</th>
                                <th class="text-center">Aksi</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (typeof kategori === 'undefined' || kategori.length === 0) { %>
                                <tr>
                                    <td colspan="3" style="text-align: center; padding: 40px 20px; color: #94a3b8;">
                                        <i class="bi bi-folder-x fs-1 d-block mb-2"></i>
                                        Belum ada data kategori.
                                    </td>
                                </tr>
                            <% } else { %>
                                <% kategori.forEach(k => { %>
                                <tr>
                                    <td class="cat-id">#CAT-<%= k.id %></td>
                                    <td class="cat-name"><%= k.nama_kategori %></td>
                                    <td style="text-align: center;">
                                        <a href="/penjualan/kategori/hapus/<%= k.id %>" class="btn-delete" onclick="return confirm('Apakah Anda yakin ingin menghapus kategori: <%= k.nama_kategori %>?');">
                                            <i class="bi bi-trash3-fill"></i> Hapus
                                        </a>
                                    </td>
                                </tr>
                                <% }) %>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <% if (typeof includeFooter !== 'undefined' && includeFooter) { %>
        <%- include('../partials/footer') %>
    <% } %>
</body>
</html>
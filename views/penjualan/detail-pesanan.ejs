<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Detail Pesanan #INV-<%= pesanan.id %> - MBP</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    
    <style>
        :root {
        --mbp-green: #03ac0e;
        --mbp-dark: #14532d;
        --mbp-light: #f0fdf4;
        --mbp-border: #bbf7d0;
        --mbp-hover: #166534;
    }
        
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: 'Inter', sans-serif; background-color: #f8fafc; display: flex; min-height: 100vh; }
        .main-content { margin-left: 260px; padding: 40px; width: calc(100% - 260px); min-height: 100vh; }
        
        .topbar { display: flex; justify-content: flex-end; align-items: center; margin-bottom: 30px; padding-bottom: 20px; border-bottom: 1px solid #e2e8f0; }
        .admin-profile { display: flex; align-items: center; gap: 12px; background: white; padding: 8px 20px; border-radius: 30px; border: 1px solid #e2e8f0; font-weight: 600; color: #1e293b; font-size: 14px; }
        .admin-profile i { color: var(--mbp-primary); font-size: 18px; }

        .mbp-card { border-radius: 16px; box-shadow: 0 4px 20px rgba(0,0,0,0.03); border: 1px solid #e2e8f0; background: #ffffff; }
        .card-title-custom { color: var(--mbp-dark); font-weight: 700; font-size: 1.1rem; border-bottom: 2px solid #f1f5f9; padding-bottom: 1rem; margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.5rem; }

        .info-row { margin-bottom: 1rem; font-size: 14px; }
        .info-label { color: #64748b; }
        .info-value { color: #1e293b; font-weight: 600; }

        .total-box { background: linear-gradient(145deg, #ffffff, var(--mbp-light)); border: 1px solid var(--mbp-border); border-left: 4px solid var(--mbp-primary); border-radius: 12px; padding: 1.25rem; margin-top: 1.5rem; }

        .back-link { color: #64748b; font-weight: 600; font-size: 14px; transition: all 0.2s; display: inline-flex; align-items: center; gap: 0.5rem; margin-bottom: 20px; text-decoration: none; }
        .back-link:hover { color: var(--mbp-dark); transform: translateX(-3px); }

        .form-label { font-size: 13px; font-weight: 600; color: #334155; }
        .form-select, .form-control { font-size: 14px; border-radius: 8px; transition: 0.3s; }
        .form-select:focus, .form-control:focus { border-color: var(--mbp-primary); box-shadow: 0 0 0 0.25rem rgba(245, 158, 11, 0.25); }
        
        .btn-update { background-color: var(--mbp-dark); color: white; border: none; font-weight: 600; padding: 10px; border-radius: 8px; width: 100%; transition: 0.2s; }
        .btn-update:hover { background-color: #92400e; }
    </style>
</head>
<body>

    <%- include('../partials/sidebar', { role: typeof role !== 'undefined' ? role : 'penjualan' }) %>

    <div class="main-content">
        <div class="topbar">
            <div class="admin-profile">
                <i class="bi bi-person-circle"></i> <%= typeof namaUser !== 'undefined' ? namaUser : 'Tim Penjualan' %>
                <span style="background: var(--mbp-light); padding: 2px 10px; border-radius: 12px; font-size: 11px; color: var(--mbp-dark); margin-left: 5px;">Penjualan</span>
            </div>
        </div>

        <a href="/penjualan/pesanan" class="back-link"><i class="bi bi-arrow-left"></i> Kembali ke Daftar Pesanan</a>
        
        <h2 class="fw-bold mb-4" style="color: var(--mbp-dark); font-size: 26px;">
            Manajemen Pesanan <span style="color: #94a3b8;">#INV-<%= pesanan.id %></span>
        </h2>

        <div class="row g-4">
            <div class="col-lg-7">
                <div class="card mbp-card mb-4">
                    <div class="card-body p-4">
                        <h5 class="card-title-custom"><i class="bi bi-person-lines-fill text-warning"></i> Data Pelanggan & Produk</h5>
                        
                        <div class="row info-row">
                            <div class="col-sm-4 info-label">Nama Pelanggan</div>
                            <div class="col-sm-8 info-value"><%= pesanan.nama_pelanggan %></div>
                        </div>
                        <div class="row info-row">
                            <div class="col-sm-4 info-label">Nomor Kontak</div>
                            <div class="col-sm-8 info-value">
                                <a href="https://wa.me/<%= pesanan.nomor_telepon.replace(/^0/, '62') %>" target="_blank" class="text-success text-decoration-none"><i class="bi bi-whatsapp"></i> <%= pesanan.nomor_telepon %></a>
                            </div>
                        </div>
                        <div class="row info-row">
                            <div class="col-sm-4 info-label">Rekening Refund</div>
                            <div class="col-sm-8 info-value font-monospace text-muted"><%= pesanan.rekening_refund || '-' %></div>
                        </div>
                        <hr class="text-muted opacity-25">
                        <div class="row info-row">
                            <div class="col-sm-4 info-label">Produk / Mutu</div>
                            <div class="col-sm-8 info-value"><span class="badge bg-secondary bg-opacity-10 text-dark border"><%= pesanan.nama_produk %></span></div>
                        </div>
                        <div class="row info-row">
                            <div class="col-sm-4 info-label">Volume Kebutuhan</div>
                            <div class="col-sm-8 info-value text-danger fw-bold"><%= pesanan.volume %> m³</div>
                        </div>
                        
                        <div class="total-box d-flex justify-content-between align-items-center">
                            <div class="info-label mb-0 fw-bold" style="color: var(--mbp-dark);">Total Tagihan</div>
                            <div class="fw-bold fs-4" style="color: var(--mbp-dark);">Rp <%= pesanan.total_harga.toLocaleString('id-ID') %></div>
                        </div>
                    </div>
                </div>

                <div class="card mbp-card">
                    <div class="card-body p-4">
                        <h5 class="card-title-custom"><i class="bi bi-truck text-warning"></i> Detail Operasional Pengecoran</h5>
                        <div class="row info-row">
                            <div class="col-sm-4 info-label">Alamat Proyek</div>
                            <div class="col-sm-8 info-value lh-base"><%= pesanan.alamat_pengiriman %></div>
                        </div>
                        <div class="row info-row mb-0">
                            <div class="col-sm-4 info-label">Jadwal Cor</div>
                            <div class="col-sm-8 info-value text-primary">
                                <i class="bi bi-calendar-event me-1"></i> <%= pesanan.waktu_pengiriman ? new Date(pesanan.waktu_pengiriman).toLocaleString('id-ID', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' }) : '-' %> WIB
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-5">
                <div class="card mbp-card mb-4" style="border-top: 4px solid var(--mbp-primary);">
                    <div class="card-body p-4">
                        <h5 class="card-title-custom"><i class="bi bi-gear-fill text-warning"></i> Kelola Status Pesanan</h5>
                        
                        <form action="/penjualan/detail-pesanan/update/<%= pesanan.id %>" method="POST">
                            
                            <input type="hidden" name="status_bayar" value="<%= pesanan.status_bayar %>">
                            <input type="hidden" name="status_pesanan" value="<%= pesanan.status_pesanan %>">

                            <div class="mb-3">
                                <label class="form-label">Status Pembayaran</label>
                                <select class="form-select fw-bold bg-light text-muted" disabled>
                                    <option value="pending" <%= pesanan.status_bayar === 'pending' ? 'selected' : '' %>>🟡 PENDING (Menunggu)</option>
                                    <option value="lunas" <%= pesanan.status_bayar === 'lunas' ? 'selected' : '' %>>🟢 LUNAS (Terverifikasi)</option>
                                    <option value="expired" <%= pesanan.status_bayar === 'expired' ? 'selected' : '' %>>🔴 EXPIRED (Hangus)</option>
                                    <option value="refund" <%= pesanan.status_bayar === 'refund' || pesanan.status_bayar === 'reffund' ? 'selected' : '' %>>⚪ REFUND (Dikembalikan)</option>
                                </select>
                                <small class="text-danger mt-1 d-block"><i class="bi bi-lock-fill"></i> Terkunci (Berubah otomatis dari sistem)</small>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Status Operasional (Order)</label>
                                <select class="form-select bg-light text-muted" disabled>
                                    <option value="menunggu_konfirmasi" <%= pesanan.status_pesanan === 'menunggu_konfirmasi' ? 'selected' : '' %>>Menunggu Konfirmasi</option>
                                    <option value="diproses" <%= pesanan.status_pesanan === 'diproses' ? 'selected' : '' %>>Diproses (Jadwal Dibuat)</option>
                                    <option value="dikirim" <%= pesanan.status_pesanan === 'dikirim' ? 'selected' : '' %>>Dikirim (Dalam Perjalanan)</option>
                                    <option value="selesai" <%= pesanan.status_pesanan === 'selesai' ? 'selected' : '' %>>Selesai (Telah Diterima)</option>
                                    <option value="dibatalkan" <%= pesanan.status_pesanan === 'dibatalkan' ? 'selected' : '' %>>Dibatalkan</option>
                                </select>
                                <small class="text-danger mt-1 d-block"><i class="bi bi-lock-fill"></i> Terkunci (Berubah otomatis dari sistem)</small>
                            </div>

                            <div class="mb-4">
                                <label class="form-label">Catatan Admin (Alasan Batal/Tolak)</label>
                                <textarea name="catatan_admin" class="form-control" rows="3" placeholder="Tulis catatan jika pesanan ditolak atau bermasalah..."><%= pesanan.catatan_admin || '' %></textarea>
                            </div>

                            <button type="submit" class="btn-update"><i class="bi bi-save2"></i> Simpan Catatan</button>
                        </form>
                    </div>
                </div>

                <div class="card mbp-card">
                    <div class="card-body p-4 text-center">
                        <h6 class="fw-bold mb-3 text-muted">Bukti Pembayaran Pelanggan</h6>
                        
                        <% if (pesanan.metode_pembayaran === 'bayar di kantor') { %>
                            <div class="p-3 bg-light rounded text-muted small">
                                <i class="bi bi-cash-coin fs-3 d-block mb-2"></i>
                                Pembayaran tunai dilakukan di loket kantor.
                            </div>
                        <% } else if (pesanan.bukti_pembayaran) { %>
                            <a href="/uploads/<%= pesanan.bukti_pembayaran %>" target="_blank" class="btn btn-outline-success w-100 fw-bold">
                                <i class="bi bi-file-earmark-image"></i> Lihat Bukti Transfer
                            </a>
                        <% } else { %>
                            <div class="p-3 bg-danger bg-opacity-10 text-danger rounded small fw-bold">
                                <i class="bi bi-x-circle d-block fs-4 mb-1"></i> Pelanggan belum mengunggah bukti.
                            </div>
                        <% } %>

                        <% if (pesanan.status_bayar === 'refund' || pesanan.status_bayar === 'reffund') { %>
                            <hr class="mt-4 mb-3 border-secondary border-opacity-25">
                            <h6 class="fw-bold mb-3 text-danger"><i class="bi bi-arrow-return-left"></i> Form Pengembalian Dana (Refund)</h6>
                            
                            <% if (!pesanan.bukti_refund) { %>
                                <div class="alert alert-warning small p-2 text-start border-0">
                                    Pesanan ini telah ditolak. <b>Wajib kembalikan dana ke pelanggan dan unggah bukti transfer.</b>
                                </div>
                                <form action="/penjualan/detail-pesanan/upload-refund" method="POST" enctype="multipart/form-data">
                                    <input type="hidden" name="pesanan_id" value="<%= pesanan.id %>">
                                    <div class="mb-3 text-start">
                                        <input type="file" name="bukti_refund" class="form-control form-control-sm border-danger" accept="image/*" required>
                                    </div>
                                    <button type="submit" class="btn btn-sm btn-danger w-100 fw-bold py-2">
                                        <i class="bi bi-upload me-2"></i>Unggah Bukti Refund
                                    </button>
                                </form>
                            <% } else { %>
                                <div class="p-2 bg-success bg-opacity-10 text-success rounded small fw-bold mb-2">
                                    <i class="bi bi-check-circle-fill"></i> Dana telah berhasil dikembalikan
                                </div>
                                <a href="/uploads/<%= pesanan.bukti_refund %>" target="_blank" class="btn btn-outline-danger w-100 fw-bold">
                                    <i class="bi bi-receipt"></i> Lihat Bukti Refund
                                </a>
                            <% } %>
                        <% } %>
                        
                    </div>
                </div>

            </div>
        </div>
    </div>
</body>
</html>
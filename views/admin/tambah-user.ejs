<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tambah User Baru - Administrator MBP</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    
    <style>
        /* ==================== CETAKAN STRUKTUR WAJIB KONSISTEN ==================== */
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { margin: 0; padding: 0; font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif; background-color: #f4f7f6; display: flex; min-height: 100vh; }
        
        .main-content { margin-left: 260px; padding: 40px; width: calc(100% - 260px); box-sizing: border-box; min-height: 100vh; }
        .topbar { display: flex; justify-content: flex-end; align-items: center; margin-bottom: 30px; padding-bottom: 20px; border-bottom: 1px solid #e2e8f0; }
        .admin-profile { display: flex; align-items: center; gap: 12px; background: white; padding: 8px 20px; border-radius: 30px; border: 1px solid #e2e8f0; font-weight: 600; color: #1e293b; font-size: 14px; box-shadow: 0 2px 5px rgba(0,0,0,0.02); }
        .admin-profile i { color: #334155; font-size: 18px; }
        /* ========================================================================== */

        /* ── Header Halaman ── */
        .page-header { margin-bottom: 30px; text-align: center; }
        .page-header h2 { font-weight: 800; color: #0f172a; font-size: 26px; margin: 0 0 5px 0; }
        .page-header p { color: #64748b; font-size: 15px; margin: 0; }

        /* ── Form Container Terpusat ── */
        .form-wrapper { max-width: 550px; margin: 0 auto; }
        .control-panel { background: white; border-radius: 16px; padding: 35px 40px; box-shadow: 0 10px 25px rgba(0,0,0,0.03); border: 1px solid #e2e8f0; margin-bottom: 30px; }
        
        .form-label { font-size: 13.5px; font-weight: 700; color: #475569; margin-bottom: 8px; display: block; }
        .input-group-custom { position: relative; margin-bottom: 20px; }
        .input-group-custom i { position: absolute; left: 14px; top: 11px; color: #94a3b8; font-size: 16px; }
        
        .form-control, .form-select { width: 100%; padding: 10px 14px 10px 40px; border: 1px solid #cbd5e1; border-radius: 8px; font-size: 14px; background-color: #f8fafc; color: #1e293b; transition: 0.2s; }
        .form-select { padding-left: 14px; } /* Select tidak butuh padding kiri besar karena icon-nya beda penempatan atau ditiadakan */
        
        .form-control:focus, .form-select:focus { border-color: #0f172a; outline: none; background-color: white; box-shadow: 0 0 0 3px rgba(15, 23, 42, 0.1); }
        
        /* ── Tombol Aksi ── */
        .btn-submit { background: #0f172a; color: white; border: none; padding: 12px 20px; border-radius: 8px; font-weight: 700; font-size: 14px; cursor: pointer; transition: 0.2s; display: flex; align-items: center; justify-content: center; gap: 8px; width: 100%; margin-top: 10px; }
        .btn-submit:hover { background: #1e293b; transform: translateY(-2px); box-shadow: 0 6px 15px rgba(15, 23, 42, 0.15); }
        
        .btn-cancel { display: block; text-align: center; margin-top: 15px; color: #64748b; font-size: 14px; font-weight: 600; text-decoration: none; transition: 0.2s; }
        .btn-cancel:hover { color: #0f172a; text-decoration: underline; }
    </style>
</head>
<body>

    <%- include('../partials/sidebar', { role: role }) %>

    <div class="main-content">
        <div class="topbar">
            <div class="admin-profile">
                <i class="bi bi-person-circle"></i>
                <%= typeof namaUser !== 'undefined' ? namaUser : 'Administrator' %>
                <span style="background: #f1f5f9; padding: 2px 10px; border-radius: 12px; font-size: 11px; color: #475569; margin-left: 5px;">Admin Master</span>
            </div>
        </div>

        <div class="form-wrapper">
            <div class="page-header">
                <h2>Tambah User Baru</h2>
                <p>Daftarkan akun karyawan atau pelanggan baru ke dalam sistem.</p>
            </div>

            <div class="control-panel">
                <form action="/admin/users/tambah" method="POST">
                    
                    <div class="mb-3">
                        <label class="form-label">Nama Lengkap</label>
                        <div class="input-group-custom">
                            <i class="bi bi-person"></i>
                            <input type="text" name="nama" class="form-control" placeholder="Masukkan nama lengkap..." required autocomplete="off">
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Alamat Email</label>
                        <div class="input-group-custom">
                            <i class="bi bi-envelope"></i>
                            <input type="email" name="email" class="form-control" placeholder="contoh@email.com" required autocomplete="off">
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Password Sistem</label>
                        <div class="input-group-custom">
                            <i class="bi bi-key"></i>
                            <input type="password" name="password" class="form-control" placeholder="Buat kata sandi yang kuat..." required>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label">Role (Hak Akses Divisi)</label>
                        <select name="role" class="form-select" required>
                            <option value="" disabled selected>— Pilih Hak Akses —</option>
                            <option value="pelanggan">Pelanggan (Customer)</option>
                            <option value="penjualan">Divisi Penjualan (Sales)</option>
                            <option value="gudang">Divisi Gudang (Inventory)</option>
                            <option value="pembelian">Divisi Pembelian (Procurement)</option>
                            <option value="admin">Administrator (IT)</option>
                        </select>
                    </div>

                    <button type="submit" class="btn-submit">
                        <i class="bi bi-floppy-fill"></i> Simpan Data User
                    </button>
                    
                    <a href="/admin/users" class="btn-cancel">Batalkan & Kembali</a>
                </form>
            </div>
        </div>
    </div>

    <%- include('../partials/footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
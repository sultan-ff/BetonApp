<%- include('../partials/header-pelanggan') %>

<style>
    .riwayat-container { max-width: 1100px; margin: 40px auto; padding: 0 20px; }
    
    /* Header Section */
    .header-section { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 30px; }
    .page-title { color: #14532d; font-weight: 800; font-size: 28px; margin: 0 0 5px 0; }
    .page-subtitle { color: #64748b; font-size: 15px; margin: 0; }
    
    .btn-pesan-lagi { border: 1.5px solid #03ac0e; color: #03ac0e; border-radius: 25px; padding: 8px 20px; font-weight: 600; text-decoration: none; transition: 0.2s; display: flex; align-items: center; gap: 6px; }
    .btn-pesan-lagi:hover { background: #03ac0e; color: white; }

    /* Table Card */
    .table-card { background: white; border-radius: 16px; box-shadow: 0 4px 20px rgba(0,0,0,0.03); border: 1px solid #f1f5f9; overflow-x: auto; }
    .table { width: 100%; margin-bottom: 0; border-collapse: collapse; }
    
    .table thead th { background-color: #fcfcfc; color: #64748b; font-size: 12px; font-weight: 700; padding: 18px 20px; text-transform: uppercase; border-bottom: 2px solid #f1f5f9; letter-spacing: 0.5px; border-top: none; }
    .table tbody td { padding: 20px; vertical-align: middle; border-bottom: 1px solid #f1f5f9; }
    .table tbody tr:last-child td { border-bottom: none; }
    .table tbody tr:hover { background-color: #fafafa; }

    /* Kolom Info Produk */
    .prod-name { font-weight: 700; color: #1e293b; font-size: 15px; margin: 0 0 3px 0; }
    .prod-id { color: #64748b; font-size: 12px; margin: 0; }
    
    /* Badge Qty */
    .qty-badge { background: #f1f5f9; color: #475569; font-size: 12px; padding: 6px 12px; border-radius: 20px; font-weight: 600; display: inline-block; border: 1px solid #e2e8f0; }
    
    /* Teks Harga */
    .price-text { font-weight: 700; color: #14532d; font-size: 15px; }

    /* Pay Badges (Lunas / Pending) */
    .pay-badge { font-size: 11px; font-weight: 700; padding: 5px 12px; border-radius: 20px; display: inline-flex; align-items: center; gap: 4px; text-transform: capitalize; }
    .pay-lunas { background: #dcfce7; color: #166534; }
    .pay-pending { background: #fef9c3; color: #854d0e; }
    .pay-refund { background: #f1f5f9; color: #475569; }
    
    /* Info Pembayaran Teks Miring */
    .info-pay-text { font-style: italic; color: #64748b; font-size: 13px; }

    /* Order Status Badges (Outlined) */
    .status-badge { font-size: 11px; font-weight: 700; padding: 6px 15px; border-radius: 20px; text-transform: uppercase; text-align: center; display: inline-block; min-width: 100px; letter-spacing: 0.5px; }
    .status-menunggu { border: 1px solid #f59e0b; color: #d97706; background: #fffbeb; }
    .status-diproses { border: 1px solid #bfdbfe; color: #1d4ed8; background: #eff6ff; }
    .status-dikirim { border: 1px solid #ddd6fe; color: #6d28d9; background: #f5f3ff; }
    .status-selesai { border: 1px solid #bbf7d0; color: #059669; background: #f0fdf4; }
    .status-dibatalkan { border: 1px solid #fecaca; color: #b91c1c; background: #fef2f2; }

    /* Tombol Aksi */
    .btn-detail { background: #03ac0e; color: white; border-radius: 20px; padding: 6px 18px; font-size: 12px; font-weight: 600; text-decoration: none; display: inline-flex; align-items: center; gap: 5px; transition: 0.2s; border: none; }
    .btn-detail:hover { background: #028a0b; color: white; }
    
    @media (max-width: 768px) {
        .header-section { flex-direction: column; align-items: flex-start; gap: 15px; }
    }
</style>

<div class="riwayat-container">
    <div class="header-section">
        <div>
            <h1 class="page-title">Riwayat Pesanan</h1>
            <p class="page-subtitle">Pantau status pemesanan beton dan sewa alat Anda secara real-time.</p>
        </div>
        <a href="/pelanggan/katalog" class="btn-pesan-lagi">
            <i class="bi bi-plus-lg"></i> Pesan Lagi
        </a>
    </div>

    <div class="table-card">
        <table class="table">
            <thead>
                <tr>
                    <th>PRODUK / MUTU</th>
                    <th>QTY / VOL</th>
                    <th>TOTAL HARGA</th>
                    <th>PEMBAYARAN</th>
                    <th>INFO PEMBAYARAN</th>
                    <th class="text-center">STATUS PESANAN</th>
                    <th>AKSI</th>
                </tr>
            </thead>
            <tbody>
                <% if (pesanan.length === 0) { %>
                    <tr>
                        <td colspan="7" class="text-center py-5 text-muted">
                            <i class="bi bi-inbox fs-1 d-block mb-3"></i>
                            Belum ada riwayat pesanan.
                        </td>
                    </tr>
                <% } else { %>
                    <% pesanan.forEach(p => { 
                        // Logika menentukan Status Order (Badge Outline) - FIX DENGAN ENUM 'DITOLAK'
                        let sOrder = p.status_pesanan ? p.status_pesanan.toLowerCase() : 'menunggu_konfirmasi';
                        
                        let badgeOrder = 'status-menunggu';
                        let textOrder = 'MENUNGGU'; 
                        
                        if(sOrder === 'diproses') { badgeOrder = 'status-diproses'; textOrder = 'DIPROSES'; }
                        else if(sOrder === 'dikirim') { badgeOrder = 'status-dikirim'; textOrder = 'DIKIRIM'; }
                        else if(sOrder === 'selesai') { badgeOrder = 'status-selesai'; textOrder = 'SELESAI'; }
                        else if(sOrder === 'dibatalkan' || sOrder === 'ditolak') { badgeOrder = 'status-dibatalkan'; textOrder = 'DIBATALKAN'; }

                        // Logika menentukan Status Bayar (Badge Lunas/Pending)
                        let sBayar = p.status_bayar ? p.status_bayar.toLowerCase() : 'pending';
                        let badgePay = 'pay-pending';
                        let iconPay = 'bi-hourglass-split';
                        if(sBayar === 'lunas') { badgePay = 'pay-lunas'; iconPay = 'bi-check-circle-fill'; }
                        else if(sBayar === 'refund' || sBayar === 'reffund') { badgePay = 'pay-refund'; iconPay = 'bi-arrow-return-left'; }
                        else if(sBayar === 'expired') { badgePay = 'pay-refund'; iconPay = 'bi-x-circle-fill'; } // Tambahan expired

                        // Logika menentukan Info Pembayaran Text Miring
                        let infoPay = 'Selesai';
                        if(sBayar !== 'lunas') {
                            if(sBayar === 'refund' || sBayar === 'expired' || sOrder === 'ditolak') {
                                infoPay = 'Pesanan Dibatalkan';
                            } else if(p.metode_pembayaran === 'transfer') {
                                infoPay = p.bukti_pembayaran ? 'Menunggu Verifikasi' : 'Belum Upload Bukti';
                            } else {
                                infoPay = 'Bayar di Loket';
                            }
                        }

                        // Logika menentukan satuan m3 / hari
                        let unit = p.nama_produk.toLowerCase().includes('sewa') || p.nama_produk.toLowerCase().includes('vibrator') ? 'hari' : 'm3';
                    %>
                    <tr>
                        <td>
                            <p class="prod-name"><%= p.nama_produk %></p>
                            <p class="prod-id">ID: #BT-<%= p.id %></p>
                        </td>
                        <td>
                            <span class="qty-badge"><%= Number(p.volume).toFixed(2) %> <%= unit %></span>
                        </td>
                        <td>
                            <span class="price-text">Rp <%= Number(p.total_harga).toLocaleString('id-ID') %>.00</span>
                        </td>
                        <td>
                            <span class="pay-badge <%= badgePay %>">
                                <i class="bi <%= iconPay %>"></i> <%= p.status_bayar %>
                            </span>
                        </td>
                        <td>
                            <span class="info-pay-text"><%= infoPay %></span>
                        </td>
                        <td class="text-center">
                            <span class="status-badge <%= badgeOrder %>">
                                <%= textOrder %>
                            </span>
                        </td>
                        <td>
                            <a href="/pelanggan/detail-pesanan/<%= p.id %>" class="btn-detail">
                                <i class="bi bi-eye-fill"></i> Detail
                            </a>
                        </td>
                    </tr>
                    <% }) %>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
<%- include('../partials/header-pelanggan') %>

<style>
    /* Container Utama Khusus Detail */
    .detail-container { max-width: 1000px; margin: 40px auto; padding: 0 20px; }
    
    /* Navigasi Breadcrumb Custom */
    .custom-breadcrumb { font-size: 14px; color: #64748b; margin-bottom: 25px; display: flex; align-items: center; gap: 5px; }
    .custom-breadcrumb a { color: #64748b; text-decoration: none; transition: 0.2s; }
    .custom-breadcrumb a:hover { color: #03ac0e; }
    .custom-breadcrumb span { color: #0f172a; font-weight: 600; }

    /* Card Detail Utama */
    .detail-card { background: white; border-radius: 16px; padding: 40px; box-shadow: 0 4px 10px rgba(0,0,0,0.03); display: flex; gap: 50px; align-items: flex-start; }
    
    /* Area Gambar (Kiri) */
    .image-section { flex: 1; display: flex; justify-content: center; align-items: center; }
    .image-section img { width: 100%; max-width: 380px; height: auto; object-fit: contain; }
    .img-placeholder { width: 100%; height: 300px; background: #f1f5f9; border-radius: 12px; display: flex; align-items: center; justify-content: center; color: #94a3b8; }
    
    /* Area Info (Kanan) */
    .info-section { flex: 1.2; }
    .kategori-badge { background: #dcfce7; color: #03ac0e; padding: 6px 15px; border-radius: 20px; font-size: 11px; font-weight: bold; text-transform: uppercase; letter-spacing: 0.5px; display: inline-block; margin-bottom: 15px; }
    .detail-title { margin: 0 0 15px 0; font-size: 32px; color: #1e293b; font-weight: 700; }
    
    /* Tambahan white-space: pre-line agar format Enter/Paragraf dari admin terbaca */
    .desc { color: #64748b; font-size: 14px; line-height: 1.7; margin-bottom: 30px; white-space: pre-line; } 
    
    /* Kotak Harga */
    .price-box { background: #f0fdf4; border: 1px solid #dcfce7; border-left: 4px solid #03ac0e; padding: 20px; border-radius: 8px; margin-bottom: 30px; }
    .price-label { font-size: 12px; font-weight: bold; color: #03ac0e; margin-bottom: 5px; letter-spacing: 0.5px; }
    .price-value { font-size: 28px; font-weight: bold; color: #03ac0e; margin: 0; }
    .price-value span { font-size: 15px; font-weight: normal; color: #64748b; }
    
    /* Grid Fitur */
    .features { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 40px; }
    .feature-item { display: flex; align-items: center; gap: 10px; font-size: 13px; color: #475569; }
    .feature-icon { color: #03ac0e; font-size: 18px; }

    /* Tombol Aksi */
    .btn-action { display: block; width: 100%; background: #03ac0e; color: white; text-align: center; padding: 15px; border-radius: 8px; font-weight: bold; font-size: 16px; text-decoration: none; transition: background 0.2s; box-sizing: border-box; }
    .btn-action:hover { background: #028a0b; color: white; }

    /* Responsif untuk layar kecil/HP */
    @media (max-width: 768px) {
        .detail-card { flex-direction: column; padding: 25px; gap: 30px; }
        .detail-title { font-size: 26px; }
    }
</style>

<div class="detail-container">
    <div class="custom-breadcrumb">
        <a href="/pelanggan/katalog"><i class="bi bi-house-door-fill me-1"></i> Katalog</a> / <span>Detail <%= produk.nama_produk %></span>
    </div>

    <div class="detail-card">
        <div class="image-section">
            <% if(produk.foto) { %>
                <img src="/uploads/<%= produk.foto %>" alt="<%= produk.nama_produk %>">
            <% } else { %>
                <div class="img-placeholder">Gambar tidak tersedia</div>
            <% } %>
        </div>

        <div class="info-section">
            <div class="kategori-badge"><%= produk.nama_kategori %></div>
            <h1 class="detail-title"><%= produk.nama_produk %></h1>
            
            <p class="desc"><%= produk.deskripsi ? produk.deskripsi : 'Deskripsi belum tersedia untuk produk ini.' %></p>

            <div class="price-box">
                <div class="price-label">HARGA SATUAN</div>
                
                <% let unit = produk.nama_produk.toLowerCase().includes('sewa') || produk.nama_produk.toLowerCase().includes('vibrator') ? 'hari' : 'm³'; %>
                
                <div class="price-value">Rp <%= Number(produk.harga).toLocaleString('id-ID') %>.00 <span>/ <%= unit %></span></div>
            </div>

            <div class="features">
                <div class="feature-item"><span class="feature-icon"><i class="bi bi-truck"></i></span> Pengiriman Cepat</div>
                <div class="feature-item"><span class="feature-icon"><i class="bi bi-clipboard2-check"></i></span> Uji Laboratorium</div>
                <div class="feature-item"><span class="feature-icon"><i class="bi bi-shield-check"></i></span> Kualitas Terjamin</div>
                <div class="feature-item"><span class="feature-icon"><i class="bi bi-building-check"></i></span> Standar MBP</div>
            </div>

            <a href="/pelanggan/checkout/<%= produk.id %>" class="btn-action">
                <i class="bi bi-cart-check-fill me-2"></i> Lanjutkan ke Pemesanan
            </a>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
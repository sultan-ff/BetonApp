<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Persetujuan PO - Panel Pembelian MBP</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    
    <style>
        /* ==================== CETAKAN STRUKTUR WAJIB KONSISTEN ==================== */
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { margin: 0; padding: 0; font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif; background-color: #f4f7f6; display: flex; min-height: 100vh; }
        
        .main-content { margin-left: 260px; padding: 40px; width: calc(100% - 260px); box-sizing: border-box; min-height: 100vh; }
        .topbar { display: flex; justify-content: flex-end; align-items: center; margin-bottom: 30px; padding-bottom: 20px; border-bottom: 1px solid #e2e8f0; }
        .admin-profile { display: flex; align-items: center; gap: 12px; background: white; padding: 8px 20px; border-radius: 30px; border: 1px solid #e2e8f0; font-weight: 600; color: #1e293b; font-size: 14px; box-shadow: 0 2px 5px rgba(0,0,0,0.02); }
        
        /* TEMA VIOLET KHUSUS PEMBELIAN */
        .admin-profile i { color: #8b5cf6; font-size: 18px; } 
        /* ========================================================================== */

        .page-header { margin-bottom: 30px; }
        .page-header h2 { font-weight: 800; color: #4c1d95; font-size: 26px; margin: 0 0 5px 0; }
        .page-header p { color: #64748b; font-size: 15px; margin: 0; }

        /* Tabel Modern */
        .card-table { background: white; border-radius: 16px; box-shadow: 0 4px 20px rgba(0,0,0,0.02); border: 1px solid #e2e8f0; overflow: hidden; }
        .card-table-header { background: #fff; padding: 20px 24px; border-bottom: 1px solid #f1f5f9; font-weight: 700; color: #1e293b; font-size: 15px; display: flex; align-items: center; gap: 8px; }
        .card-table-header i { color: #8b5cf6; }
        
        .table { width: 100%; margin-bottom: 0; border-collapse: collapse; }
        .table thead th { background-color: #f8fafc; color: #64748b; font-size: 11.5px; font-weight: 700; text-transform: uppercase; padding: 16px 24px; border-bottom: 1px solid #e2e8f0; border-top: none; letter-spacing: 0.5px; }
        .table tbody td { padding: 18px 24px; vertical-align: middle; border-bottom: 1px solid #f1f5f9; font-size: 14px; color: #334155; }
        .table tbody tr:hover { background-color: #fcfcfc; }

        .req-tag { font-weight: 800; color: #0f172a; font-family: monospace; }
        .sup-name { font-weight: 700; color: #1e293b; }
        .mat-name { background: #f1f5f9; color: #475569; padding: 4px 10px; border-radius: 6px; font-size: 12.5px; font-weight: 700; border: 1px solid #e2e8f0; }
        
        /* Badges Status PO */
        .badge-po { padding: 6px 14px; border-radius: 20px; font-size: 11px; font-weight: 700; text-transform: uppercase; display: inline-block; letter-spacing: 0.5px; }
        .po-menunggu { background: #fef3c7; color: #d97706; border: 1px solid #fde68a; }
        .po-disetujui { background: #e0f2fe; color: #0284c7; border: 1px solid #bae6fd; }
        .po-selesai { background: #dcfce7; color: #16a34a; border: 1px solid #bbf7d0; }

        /* Tombol Aksi */
        .btn-action { padding: 6px 12px; border-radius: 6px; font-size: 12.5px; font-weight: 600; text-decoration: none; transition: 0.2s; display: inline-flex; align-items: center; gap: 5px; border: none; cursor: pointer; }
        .btn-approve { background: #8b5cf6; color: white; }
        .btn-approve:hover { background: #7c3aed; color: white; transform: translateY(-1px); }
        .btn-print { background: white; border: 1px solid #cbd5e1; color: #475569; }
        .btn-print:hover { background: #f1f5f9; color: #0f172a; border-color: #94a3b8; }
    </style>
</head>
<body>

    <%- include('../partials/sidebar', { role: role }) %>

    <div class="main-content">
        <div class="topbar">
            <div class="admin-profile">
                <i class="bi bi-person-circle"></i>
                <%= typeof namaUser !== 'undefined' ? namaUser : 'Tim Pembelian' %>
                <span style="background: #f3e8ff; padding: 2px 10px; border-radius: 12px; font-size: 11px; color: #7c3aed; margin-left: 5px;">Pembelian</span>
            </div>
        </div>

        <div class="page-header">
            <h2>Persetujuan Pengadaan Barang</h2>
            <p>Validasi dan setujui permintaan pengadaan stok produk jadi dari divisi Gudang.</p>
        </div>

        <div class="card-table">
            <div class="card-table-header">
                <i class="bi bi-inbox-fill"></i> Antrean Permintaan (Purchase Requisition)
            </div>
            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr>
                            <th>No. Referensi</th>
                            <th>Tanggal Masuk</th>
                            <th>Supplier Tujuan</th>
                            <th>Produk Jadi</th>
                            <th style="text-align: center;">Jumlah</th>
                            <th>Status</th>
                            <th style="text-align: center;">Tindakan</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (typeof listPO === 'undefined' || listPO.length === 0) { %>
                            <tr><td colspan="7" class="text-center py-5 text-muted"><i class="bi bi-check-circle fs-2 d-block mb-2"></i>Tidak ada antrean permintaan pengadaan.</td></tr>
                        <% } else { %>
                            <% listPO.forEach(item => { %>
                            <tr>
                                <td class="req-tag">#REQ-MBP-<%= item.id %></td>
                                <td><%= new Date(item.tanggal).toLocaleDateString('id-ID', { dateStyle: 'medium' }) %></td>
                                <td class="sup-name"><%= item.nama_supplier %></td>
                                <td><span class="mat-name"><%= item.nama_produk %></span></td>
                                <td style="text-align: center; font-weight: 800;"><%= item.jumlah %></td>
                                <td>
                                    <span class="badge-po po-<%= item.status %>"><%= item.status %></span>
                                </td>
                                <td style="text-align: center;">
                                    <% if (item.status === 'menunggu') { %>
                                        <form action="/pembelian/po/approve/<%= item.id %>" method="POST" style="display: inline;">
                                            <button type="submit" class="btn-action btn-approve" onclick="return confirm('Apakah Anda yakin menyetujui pengadaan ini? Dokumen PO resmi akan diterbitkan.')">
                                                <i class="bi bi-check2-square"></i> Setujui
                                            </button>
                                        </form>
                                    <% } else { %>
                                        <a href="/pembelian/po/cetak/<%= item.id %>" target="_blank" class="btn-action btn-print">
                                            <i class="bi bi-printer"></i> Cetak PO
                                        </a>
                                    <% } %>
                                </td>
                            </tr>
                            <% }) %>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</body>
</html>
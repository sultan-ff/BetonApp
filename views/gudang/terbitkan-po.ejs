<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Permintaan Pembelian - Panel Gudang MBP</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    
    <style>
        /* ==================== CETAKAN STRUKTUR WAJIB KONSISTEN ==================== */
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { margin: 0; padding: 0; font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif; background-color: #f4f7f6; display: flex; min-height: 100vh; }
        
        .main-content { margin-left: 260px; padding: 40px; width: calc(100% - 260px); box-sizing: border-box; min-height: 100vh; }
        .topbar { display: flex; justify-content: flex-end; align-items: center; margin-bottom: 30px; padding-bottom: 20px; border-bottom: 1px solid #e2e8f0; }
        .admin-profile { display: flex; align-items: center; gap: 12px; background: white; padding: 8px 20px; border-radius: 30px; border: 1px solid #e2e8f0; font-weight: 600; color: #1e293b; font-size: 14px; box-shadow: 0 2px 5px rgba(0,0,0,0.02); }
        .admin-profile i { color: #0891b2; font-size: 18px; }
        /* ========================================================================== */

        .page-header { margin-bottom: 30px; }
        .page-header h2 { font-weight: 800; color: #164e63; font-size: 26px; margin: 0 0 5px 0; }
        .page-header p { color: #64748b; font-size: 15px; margin: 0; }

        /* Panel Form */
        .control-panel { background: white; border-radius: 16px; padding: 25px 30px; box-shadow: 0 4px 15px rgba(0,0,0,0.02); border: 1px solid #e2e8f0; margin-bottom: 30px; }
        .panel-title { font-size: 15px; font-weight: 700; color: #1e293b; margin-bottom: 15px; display: flex; align-items: center; gap: 8px; }
        .panel-title i { color: #0891b2; }
        
        .form-label { font-size: 13px; font-weight: 700; color: #475569; margin-bottom: 8px; display: block; }
        .form-control, .form-select { width: 100%; padding: 10px 14px; border: 1px solid #cbd5e1; border-radius: 8px; font-size: 14px; background-color: #f8fafc; color: #1e293b; transition: 0.2s; }
        .form-control:focus, .form-select:focus { border-color: #0891b2; outline: none; background-color: white; box-shadow: 0 0 0 3px rgba(8, 145, 178, 0.15); }
        
        .btn-submit { background: #0891b2; color: white; border: none; padding: 10px 20px; border-radius: 8px; font-weight: 700; font-size: 14px; cursor: pointer; transition: 0.2s; display: flex; align-items: center; justify-content: center; gap: 8px; height: 42px; margin-top: 27px; width: 100%; }
        .btn-submit:hover { background: #0e7490; transform: translateY(-1px); box-shadow: 0 4px 10px rgba(8, 145, 178, 0.2); }

        /* Tabel Modern */
        .card-table { background: white; border-radius: 16px; box-shadow: 0 4px 20px rgba(0,0,0,0.02); border: 1px solid #e2e8f0; overflow: hidden; }
        .card-table-header { background: #fff; padding: 20px 24px; border-bottom: 1px solid #f1f5f9; font-weight: 700; color: #1e293b; font-size: 15px; display: flex; align-items: center; gap: 8px; }
        
        .table { width: 100%; margin-bottom: 0; border-collapse: collapse; }
        .table thead th { background-color: #f8fafc; color: #64748b; font-size: 11.5px; font-weight: 700; text-transform: uppercase; padding: 16px 24px; border-bottom: 1px solid #e2e8f0; border-top: none; letter-spacing: 0.5px; }
        .table tbody td { padding: 18px 24px; vertical-align: middle; border-bottom: 1px solid #f1f5f9; font-size: 14px; color: #334155; }
        .table tbody tr:hover { background-color: #fcfcfc; }

        .req-tag { font-weight: 800; color: #0f172a; font-family: monospace; }
        .sup-name { font-weight: 700; color: #1e293b; }
        .mat-name { background: #f1f5f9; color: #475569; padding: 4px 10px; border-radius: 6px; font-size: 12.5px; font-weight: 700; border: 1px solid #e2e8f0; }
        
        /* Badges Status Permintaan (Pastel Internal) */
        .badge-req { padding: 6px 14px; border-radius: 20px; font-size: 11px; font-weight: 700; text-transform: uppercase; display: inline-block; letter-spacing: 0.5px; }
        .req-diajukan { background: #e0f2fe; color: #0284c7; border: 1px solid #bae6fd; }
        .req-diproses { background: #fef3c7; color: #d97706; border: 1px solid #fde68a; }
        .req-selesai { background: #dcfce7; color: #16a34a; border: 1px solid #bbf7d0; }
    </style>
</head>
<body>

    <%- include('../partials/sidebar', { role: role }) %>

    <div class="main-content">
        <div class="topbar">
            <div class="admin-profile">
                <i class="bi bi-person-circle"></i>
                <%= typeof namaUser !== 'undefined' ? namaUser : 'Tim Gudang' %>
                <span style="background: #f1f5f9; padding: 2px 10px; border-radius: 12px; font-size: 11px; color: #64748b; margin-left: 5px;">Gudang</span>
            </div>
        </div>

        <div class="page-header">
            <h2>Permintaan Order Pembelian</h2>
            <p>Ajukan permohonan pengadaan stok material kritis ke divisi pembelian.</p>
        </div>

        <div class="control-panel">
            <div class="panel-title">
                <i class="bi bi-file-earmark-arrow-up-fill"></i> Buat Permintaan Pengadaan
            </div>
            
            <form action="/gudang/po/terbit" method="POST">
                <div class="row gx-3">
                    <div class="col-md-3">
                        <label class="form-label">Rekomendasi Supplier</label>
                        <select name="supplier_id" class="form-select" required>
                            <option value="" disabled selected>— Pilih Supplier —</option>
                            <% if (typeof listSupplier !== 'undefined') { %>
                                <% listSupplier.forEach(s => { %>
                                    <option value="<%= s.id %>"><%= s.nama_supplier %></option>
                                <% }) %>
                            <% } %>
                        </select>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Material yang Dibutuhkan</label>
                        <select name="produk_id" class="form-select" required>
                            <option value="" disabled selected>— Pilih Material —</option>
                            <% if (typeof listProduk !== 'undefined') { %>
                                <% listProduk.forEach(p => { %>
                                    <option value="<%= p.id %>"><%= p.nama_produk %></option>
                                <% }) %>
                            <% } %>
                        </select>
                    </div>

                    <div class="col-md-2">
                        <label class="form-label">Jumlah Diperlukan</label>
                        <input type="number" name="jumlah" class="form-control" placeholder="0" min="1" required>
                    </div>

                    <div class="col-md-2">
                        <label class="form-label">Alasan / Catatan</label>
                        <input type="text" name="keterangan" class="form-control" placeholder="Stok menipis, dll..." autocomplete="off">
                    </div>

                    <div class="col-md-2">
                        <button type="submit" class="btn-submit" style="background: #0284c7;">
                            <i class="bi bi-cursor-fill"></i> Lempar Ke Pembelian
                        </button>
                    </div>
                </div>
            </form>
        </div>

        <div class="card-table">
            <div class="card-table-header">
                <i class="bi bi-arrow-left-right text-info"></i> Tracking Status Permintaan Logistik
            </div>
            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr>
                            <th>No. Permintaan</th>
                            <th>Tanggal Lempar</th>
                            <th>Rekomendasi Supplier</th>
                            <th>Material / Produk</th>
                            <th style="text-align: center;">Jumlah</th>
                            <th>Keterangan</th>
                            <th>Status Pembelian</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (typeof listPO === 'undefined' || listPO.length === 0) { %>
                            <tr><td colspan="7" class="text-center py-5 text-muted"><i class="bi bi-send-x fs-2 d-block mb-2"></i>Belum ada permintaan yang dikirim ke bagian pembelian.</td></tr>
                        <% } else { %>
                            <% listPO.forEach(item => { 
                                // Mapping nama class status agar fleksibel
                                let statusClass = 'req-diajukan';
                                let statusLabel = 'Diajukan';
                                if (item.status === 'disetujui') { statusClass = 'req-diproses'; statusLabel = 'Diproses Pembelian'; }
                                else if (item.status === 'selesai') { statusClass = 'req-selesai'; statusLabel = 'Barang Diterima'; }
                            %>
                            <tr>
                                <td class="req-tag">#REQ-MBP-<%= item.id %></td>
                                <td>
                                    <%= new Date(item.tanggal).toLocaleDateString('id-ID', { dateStyle: 'medium' }) %>
                                </td>
                                <td class="sup-name"><%= item.nama_supplier %></td>
                                <td><span class="mat-name"><%= item.nama_produk %></span></td>
                                <td style="text-align: center; font-weight: 800;"><%= item.jumlah %> m³</td>
                                <td class="text-muted small"><%= item.keterangan || '-' %></td>
                                <td>
                                    <span class="badge-req <%= statusClass %>"><%= statusLabel %></span>
                                </td>
                            </tr>
                            <% }) %>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</body>
</html>
<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard Gudang - MBP</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    
    <style>
        /* ==================== CETAKAN STRUKTUR WAJIB KONSISTEN ==================== */
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { margin: 0; padding: 0; font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif; background-color: #f4f7f6; display: flex; min-height: 100vh; }
        
        .main-content { margin-left: 260px; padding: 40px; width: calc(100% - 260px); box-sizing: border-box; min-height: 100vh; }
        .topbar { display: flex; justify-content: flex-end; align-items: center; margin-bottom: 30px; padding-bottom: 20px; border-bottom: 1px solid #e2e8f0; }
        .admin-profile { display: flex; align-items: center; gap: 12px; background: white; padding: 8px 20px; border-radius: 30px; border: 1px solid #e2e8f0; font-weight: 600; color: #1e293b; font-size: 14px; box-shadow: 0 2px 5px rgba(0,0,0,0.02); }
        .admin-profile i { color: #0891b2; font-size: 18px; } /* Warna ikon cyan untuk gudang */
        /* ========================================================================== */

        /* ── Banner Selamat Datang ── */
        .welcome-banner { 
            background: linear-gradient(135deg, #ffffff 0%, #ecfeff 100%); 
            border: 1px solid #cffafe; border-left: 5px solid #0891b2; border-radius: 16px; 
            padding: 35px 40px; margin-bottom: 40px; box-shadow: 0 10px 15px -3px rgba(8, 145, 178, 0.05); 
        }
        .welcome-banner h2 { margin: 0 0 10px 0; font-size: 26px; font-weight: 800; color: #164e63; }
        .welcome-banner p { margin: 0; font-size: 15px; color: #475569; line-height: 1.6; }

        /* ── Grid Statistik Cepat ── */
        .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 20px; margin-bottom: 40px; }
        .stat-card { background: white; border-radius: 16px; padding: 25px; border: 1px solid #e2e8f0; box-shadow: 0 4px 6px rgba(0,0,0,0.02); display: flex; align-items: center; gap: 20px; }
        .stat-icon { width: 55px; height: 55px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 24px; }
        
        .bg-cyan { background: #cffafe; color: #0891b2; }
        .bg-red { background: #fee2e2; color: #dc2626; }
        .bg-purple { background: #f3e8ff; color: #9333ea; }
        
        .stat-text h3 { margin: 0 0 5px 0; font-size: 24px; font-weight: 800; color: #1e293b; }
        .stat-text p { margin: 0; font-size: 13px; color: #64748b; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; }

        /* ── Grid Menu Operasional ── */
        .section-title { font-size: 16px; font-weight: 700; color: #1e293b; margin-bottom: 20px; text-transform: uppercase; letter-spacing: 0.5px; display: flex; align-items: center; gap: 8px; }
        .grid-cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 25px; }
        
        .action-card { 
            background: white; border-radius: 16px; padding: 25px; border: 1px solid #e2e8f0; 
            box-shadow: 0 4px 6px rgba(0,0,0,0.02); display: flex; align-items: center; gap: 20px; 
            text-decoration: none; color: #1e293b; transition: 0.2s ease; 
        }
        .action-card:hover { transform: translateY(-4px); border-color: #0891b2; box-shadow: 0 12px 20px rgba(8, 145, 178, 0.08); }
        .action-text h4 { margin: 0 0 4px 0; font-size: 16px; font-weight: 700; }
        .action-text p { margin: 0; font-size: 13px; color: #64748b; line-height: 1.4; }
    </style>
</head>
<body>

    <%- include('../partials/sidebar', { role: 'gudang' }) %>

    <div class="main-content">
        <div class="topbar">
            <div class="admin-profile">
                <i class="bi bi-person-circle"></i>
                <%= typeof namaUser !== 'undefined' ? namaUser : 'Tim Gudang' %>
                <span style="background: #f1f5f9; padding: 2px 10px; border-radius: 12px; font-size: 11px; color: #64748b; margin-left: 5px; text-transform: capitalize;">
                    Gudang
                </span>
            </div>
        </div>

        <div class="welcome-banner">
            <h2>Dashboard Gudang & Inventori</h2>
            <p>Selamat datang di pusat kendali persediaan PT Mitrabeton Perkasa.</p>
        </div>

    

        <div class="section-title">
            <i class="bi bi-grid-1x2-fill text-info"></i> Menu Manajemen Gudang
        </div>
        
        <div class="grid-cards">
            <a href="/gudang/cek-stok" class="action-card">
                <div class="stat-icon bg-cyan"><i class="bi bi-layers-fill"></i></div>
                <div class="action-text">
                    <h4>Kelola Stok Produk</h4>
                    <p>Pantau sisa stok dan perbarui kuantitas fisik.</p>
                </div>
            </a>
            
            <a href="/gudang/laporan-stok" class="action-card">
                <div class="stat-icon bg-red"><i class="bi bi-file-earmark-bar-graph-fill"></i></div>
                <div class="action-text">
                    <h4>Laporan Inventori</h4>
                    <p>Cetak rekapitulasi pergerakan barang secara berkala.</p>
                </div>
            </a>
        </div>

    </div>

</body>
</html>